# Browser Firebase configuration from Firebase Console > Project settings > Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin service account fields for server-side token verification on Vercel.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server-side access control. Comma-separate additional addresses later.
ALLOWED_EMAILS=zaking17@gmail.com

# MongoDB Atlas production connection.
MONGODB_URI=
MONGODB_DB=brainshare

# AI_PROVIDER supports mock, openai, or anthropic.
# The mock provider makes local development work without an API key.
AI_PROVIDER=openai
AI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local-only switches are set automatically by `pnpm dev:local`.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
