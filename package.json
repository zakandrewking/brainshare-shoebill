{
  "name": "brainshare-shoebill",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:app": "next dev",
    "dev:mock": "AI_PROVIDER=mock AI_MODEL=local-mock pnpm dev:local",
    "dev:firebase": "node scripts/firebase-emulator.mjs",
    "dev:infra": "docker compose up -d --wait mongodb",
    "dev:local": "pnpm dev:infra && node scripts/dev.mjs",
    "dev:down": "docker compose down",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm test && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@ai-sdk/openai": "^3.0.69",
    "@base-ui/react": "^1.5.0",
    "ai": "^6.0.199",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^1.17.0",
    "mongodb": "^7.3.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "firebase-tools": "^15.19.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
